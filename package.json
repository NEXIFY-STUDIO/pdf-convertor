{
  "name": "pdf-html-forge",
  "version": "1.0.0",
  "description": "A production-ready browser-only Progressive Web App that converts uploaded PDF files into highly visually accurate offline HTML exports.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run src/test/sourceOfTruth.test.ts src/test/mistralClient.test.ts",
    "test:integration": "vitest run src/test/LeftPanel.integration.test.tsx src/test/RightPanel.test.tsx src/test/BatchGenerator.test.tsx src/test/VubLayout.test.tsx",
    "test:v2": "vitest run src/test/normalizeTransaction.test.ts src/test/transactionRender.test.ts src/test/fieldBlueprint.test.ts src/test/InspectorPanel.test.tsx src/test/zipExport.test.ts src/test/RightPanel.test.tsx",
    "test:v2:coverage": "vitest run --coverage src/test/normalizeTransaction.test.ts src/test/transactionRender.test.ts src/test/fieldBlueprint.test.ts src/test/InspectorPanel.test.tsx src/test/zipExport.test.ts src/test/RightPanel.test.tsx",
    "test:stress": "vitest run src/test/MemoryProfiler.test.ts",
    "test:security": "vitest run src/test/security.test.ts",
    "test:coverage": "vitest --coverage",
    "test:ai": "vitest run tests/production/ai_extraction.test.ts",
    "test:pdf": "vitest run tests/production/pdf_generation.test.ts",
    "test:visual": "vitest run tests/production/visual_regression.test.ts",
    "test:data": "vitest run tests/production/data_validation.test.ts",
    "test:production_sec": "vitest run tests/production/security.test.ts",
    "test:performance": "vitest run tests/production/performance.test.ts",
    "test:production": "npm run test:ai && npm run test:pdf && npm run test:visual && npm run test:data && npm run test:production_sec && npm run test:performance",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "tailscale:proxy": "node scripts/tailscale-vercel-proxy.mjs",
    "tailscale:serve": "tailscale serve --set-path=/vub --bg http://127.0.0.1:4180",
    "dev:legacy": "bash scripts/legacy-dev.sh",
    "smoke": "node scripts/smoke-mistral.mjs",
    "smoke:live": "vitest run src/test/mistralClient.live.test.ts",
    "test:all": "bash scripts/test-all.sh",
    "test:all:from3": "TEST_FROM=3 bash scripts/test-all.sh",
    "test:fixtures": "node scripts/generate-test-fixtures.mjs",
    "push:github": "bash scripts/push-github.sh"
  },
  "dependencies": {
    "@react-pdf/renderer": "^3.4.5",
    "autoprefixer": "^10.4.17",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^4.3.136",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "pdf",
    "html",
    "converter",
    "pwa",
    "offline",
    "export"
  ],
  "author": "",
  "license": "MIT"
}
