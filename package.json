{
  "name": "pdf-html-forge",
  "version": "1.0.0",
  "description": "A production-ready browser-only Progressive Web App that converts uploaded PDF files into highly visually accurate offline HTML exports.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.3.136",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "pdf",
    "html",
    "converter",
    "pwa",
    "offline",
    "export"
  ],
  "author": "",
  "license": "MIT"
}
